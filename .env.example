# ── Backend ──────────────────────────────────────────────────────────────────
# Runtime: transaction pooler (puerto 6543, host *.pooler.supabase.com)
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-X-<region>.pooler.supabase.com:6543/postgres
# Migraciones (drizzle-kit): conexion directa (puerto 5432, host db.*.supabase.co)
DIRECT_URL=postgresql://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# Formato nuevo de claves (reemplaza a la legacy service_role)
SUPABASE_SECRET_KEY=sb_secret_...
# JWT: no hay secreto compartido — el proyecto usa JWT Signing Keys (ES256).
# El backend verifica tokens contra ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
PORT=4000

# ── Seed de desarrollo (solo lo usa `npm run db:seed`) ──────────────────────
SEED_ADMIN_EMAIL=owner@example.com
SEED_ADMIN_PASSWORD=...
SEED_SUPERADMIN_EMAIL=super@example.com
SEED_SUPERADMIN_PASSWORD=...

# ── Frontend (prefijo VITE_ para que Vite las exponga al cliente) ───────────
VITE_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# Formato nuevo (reemplaza a la legacy anon key); es publica por diseno
VITE_SUPABASE_ANON_KEY=sb_publishable_...
VITE_API_URL=http://localhost:4000

# ── Se agregan recien en T6 (checkout) ───────────────────────────────────────
# MP_ACCESS_TOKEN=
# MP_WEBHOOK_SECRET=
# RESEND_API_KEY=
